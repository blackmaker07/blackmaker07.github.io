# Ignore metadata generated by Jekyll
_site/
.sass-cache/
.jekyll-cache/
.jekyll-metadata

# Ignore folders generated by Bundler
.bundle/

# Ignore Gems except Bootstrap assets
vendor/*
!vendor/bundle/

vendor/bundle/*
!vendor/bundle/ruby

vendor/bundle/ruby/*
!vendor/bundle/ruby/3.2.0

vendor/bundle/ruby/3.2.0/*
!vendor/bundle/ruby/3.2.0/gems

vendor/bundle/ruby/3.2.0/gems/*
!vendor/bundle/ruby/3.2.0/gems/bootstrap-5.3.2/

vendor/bundle/ruby/3.2.0/gems/bootstrap-5.3.2/*
!vendor/bundle/ruby/3.2.0/gems/bootstrap-5.3.2/assets
